# ECAS local environment template
# Copy to .env before running the app.
# Mock mode is the recommended setup for portfolio demos.

# Demo / portfolio mode
NUXT_PUBLIC_MOCK_MODE=true

# Base API URL
# - Mock mode: leave as /api to use Nitro mock endpoints bundled in this repo
# - Real backend mode: replace with your backend base URL
NUXT_PUBLIC_BASE_URL_API=/api

# Optional in mock mode. Required only if you want live Firebase-backed auth/storage.
NUXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NUXT_PUBLIC_FIREBASE_MESSAGE_SENDER_ID=your-message-sender-id
NUXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NUXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Optional in mock mode. Only needed if a live Stripe checkout is restored.
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
